{% assign entry_key = entry.key %}

<div id="{{ entry_key }}"
     class="pub-entry"
     data-categories="{{ entry.categories | join: ' ' | downcase }}"
     data-year="{{ entry.year }}"
     data-authors="{{ entry.author }}"
     data-title="{{ entry.title }}"
     data-venue="{{ entry.venue }}">

  {%- if entry.thumbnail %}
    <div class="pub-thumbnail">
      <img src="{{ entry.thumbnail | relative_url }}" alt="Thumbnail for {{ entry.title }}">
    </div>
  {%- endif %}

  <div class="pub-content">

    <!-- APSA CSL-formatted citation -->
    <div class="pub-citation">
      {{ reference }}
    </div>

    <!-- Links: PDF, Code, DOI, URL -->
    <div class="pub-links">
      {%- if entry.pdf %}
        <a href="{{ entry.pdf | relative_url }}" class="btn btn-sm btn-outline-primary">PDF</a>
      {%- endif %}
      {%- if entry.code %}
        <a href="{{ entry.code }}" class="btn btn-sm btn-outline-primary">Code</a>
      {%- endif %}
      {%- if entry.doi %}
        <a href="https://doi.org/{{ entry.doi }}" class="btn btn-sm btn-outline-primary">DOI</a>
      {%- endif %}
      {%- if entry.url %}
        <a href="{{ entry.url }}" class="btn btn-sm btn-outline-primary">Link</a>
      {%- endif %}
    </div>

    <!-- Abstract toggle -->
    {%- if entry.abstract %}
      <details class="pub-abstract">
        <summary>Abstract</summary>
        <p>{{ entry.abstract }}</p>
      </details>
    {%- endif %}

  </div>

</div>
